---
import fs from 'node:fs/promises';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import { marked } from 'marked';
import { specMeta } from '../lib/spec-meta';

const markdownPath = path.resolve(process.cwd(), 'authorization-model.md');
const markdownContent = await fs.readFile(markdownPath, 'utf8');

marked.setOptions({ gfm: true });

let htmlContent = marked.parse(markdownContent) as string;

// Remove document header duplicated in masthead (h1, subtitle, version) before first section.
htmlContent = htmlContent.replace(
	/^<h1>[\s\S]*?(?=<h2>)/,
	'',
);

// Remove horizontal rules between sections (h2 borders provide separation).
htmlContent = htmlContent.replace(/<hr>\n?/g, '');
---

<Layout title={specMeta.title} description={specMeta.description}>
	<div class="spec">
		<article set:html={htmlContent} />
	</div>
</Layout>
